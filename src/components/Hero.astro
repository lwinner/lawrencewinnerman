---
// Hero — sigil + name lockup + locked tagline.
---
<section id="top" class="hero">
  <div class="container hero-grid">
    <div class="hero-mark">
      <img src="/sigil-master.svg" alt="Lawrence Winnerman sigil — nested chevron" width="420" height="420" />
    </div>
    <div class="hero-name">
      <h1 class="display-name">
        <span>Lawrence</span>
        <span>Winnerman</span>
      </h1>
      <hr class="rule-red" aria-hidden="true" />
      <p class="tagline">
        <span>Writing the hinge.</span>
        <span>Building the future.</span>
      </p>
    </div>
  </div>
</section>

<style>
  .hero {
    padding-top: clamp(3rem, 8vw, 6rem);
    padding-bottom: clamp(4rem, 10vw, 8rem);
  }
  .hero-grid {
    display: grid;
    grid-template-columns: minmax(auto, 380px) 1fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: center;
  }
  .hero-mark img {
    width: 100%;
    height: auto;
    max-width: 380px;
    aspect-ratio: 1 / 1;
  }
  .hero-name h1 span { display: block; }
  @media (max-width: 720px) {
    .hero-grid { grid-template-columns: 1fr; text-align: center; }
    .hero-mark { justify-self: center; max-width: 220px; }
    .hero-mark img { max-width: 220px; }
    .rule-red { margin-inline: auto; }
  }
</style>
