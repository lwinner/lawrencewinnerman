---
const email = "lwinner@gmail.com";
const asks = [
  { label: "Podcasts & press", note: "Long-form audio, panels, on-the-record commentary." },
  { label: "Speaking", note: "Conferences and panels at the seam of politics, tech, and culture." },
  { label: "Advising", note: "Founders and operators building media in the new mode." },
];
---
<section id="contact" class="contact">
  <div class="container">
    <p class="eyebrow">Contact</p>
    <h2>The door is open.</h2>
    <p class="contact-lead">
      For collaborations, sponsorships, speaking invitations, podcast bookings, advising conversations, or just to say hello&mdash;write directly.
    </p>

    <div class="asks" role="list">
      {asks.map(a => (
        <p class="ask" role="listitem">
          <span class="ask-label">{a.label}</span>
          {a.note}
        </p>
      ))}
    </div>

    <div class="contact-actions">
      <a href={`mailto:${email}?subject=Hello%20Lawrence`} class="btn">
        Email me <span aria-hidden="true">→</span>
      </a>
      <a href={`mailto:${email}?subject=Press%20%26%20booking%20kit%20request`} class="btn btn-secondary">
        Press &amp; booking kit
      </a>
    </div>

    <ul class="elsewhere" role="list">
      <li><a href="https://lwinner.substack.com" rel="noopener">Substack</a></li>
      <li><a href="https://www.linkedin.com/in/lawrencewinnerman" rel="noopener">LinkedIn</a></li>
      <li><a href="https://bsky.app/profile/lawrencewinnerman.com" rel="noopener">Bluesky</a></li>
    </ul>
  </div>
</section>

<style>
  .contact-lead {
    max-width: 56ch;
    margin: 0 0 2rem;
  }
  .asks {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    max-width: 56ch;
    margin: 0 0 2.5rem;
  }
  .ask { margin: 0; font-size: var(--fs-body); }
  .ask-label {
    display: block;
    font-family: var(--font-ui);
    font-weight: 600;
    font-size: var(--fs-eyebrow);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--lw-red);
    margin-bottom: 0.2rem;
  }
  .contact-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-bottom: 2.5rem;
  }
  .btn-secondary {
    background: transparent;
    color: var(--lw-slate);
    border: 1px solid var(--lw-rule);
  }
  .btn-secondary:hover {
    color: var(--lw-red);
    border-color: var(--lw-red);
    opacity: 1;
  }
  .elsewhere {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: 1.75rem;
    flex-wrap: wrap;
    font-family: var(--font-ui);
    font-weight: 500;
    font-size: var(--fs-small);
    letter-spacing: 0.04em;
  }
  .elsewhere a { color: var(--lw-slate); }
  .elsewhere a:hover { color: var(--lw-red); }
</style>
