---
const year = new Date().getFullYear();
---
<footer class="footer">
  <hr class="sep" />
  <div class="container footer-inner">
    <div class="footer-subscribe">
      <p class="subscribe-label">The newsletter</p>
      <div class="substack-embed">
        <iframe
          src="https://lwinner.substack.com/embed?transparent=1"
          title="Subscribe to Lawrence Winnerman's Substack"
          width="480"
          height="320"
          loading="lazy"
          frameborder="0"
          scrolling="no"
        ></iframe>
      </div>
    </div>
    <p class="meta">© {year} Lawrence Winnerman · Writing the hinge. Building the future.</p>
  </div>
</footer>

<style>
  .footer { padding: 2rem 0 4rem; }
  .footer-inner { padding-top: 1.5rem; }
  .footer-subscribe { margin: 0 0 2.5rem; }
  .subscribe-label {
    font-family: var(--font-ui);
    font-weight: 600;
    font-size: var(--fs-eyebrow);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--lw-muted);
    margin: 0 0 1rem;
  }
  .substack-embed { max-width: 480px; }
  .substack-embed iframe {
    display: block;
    width: 100%;
    height: 320px;
    border: 0;
    background: transparent;
  }
  .meta { margin: 0; }
</style>
